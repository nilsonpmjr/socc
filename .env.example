# Renomeie este arquivo para .env e preencha os valores

# API Key da Threat Intelligence Tool (fornecida em momento oportuno)
THREAT_INTEL_API_KEY=

# URL base do backend da Threat Intelligence Tool (padrão local)
TI_API_BASE_URL=http://localhost:8000

# Credenciais do backend TI (padrão do seed_users.py)
TI_API_USER=admin
TI_API_PASS=iteam123

# Caminho absoluto para o threat_check.py
THREAT_CHECK_SCRIPT=C:\Users\Nilson.Miranda\Threat-Intelligence-Tool\backend\threat_check.py

# Pasta de saída para notas geradas
OUTPUT_DIR=C:\Users\Nilson.Miranda\OneDrive - iT.eam\Documentos\Alertas\Notas_Geradas

# Pasta raiz do projeto Alertas (para carregar regras, SOP e modelos)
ALERTAS_ROOT=C:\Users\Nilson.Miranda\OneDrive - iT.eam\Documentos\Alertas

# Porta da aplicação SOC Copilot
SOC_PORT=8080

# Máximo de IOCs individuais consultados por ofensa (para evitar rate limit)
MAX_TI_IOCS=5

# ---------------------------------------------------------------------------
# LLM — camada de análise inteligente (opcional)
# ---------------------------------------------------------------------------
# Ativa o LLM na camada semi-LLM (false = modo determinístico puro)
LLM_ENABLED=false

# Provider: "ollama" (local, padrão) ou "anthropic" (nuvem)
LLM_PROVIDER=ollama

# Timeout em segundos (Ollama pode ser mais lento na 1ª execução — GPU/CPU)
LLM_TIMEOUT=60

# --- Ollama (local) ---
# Instale em: https://ollama.com  |  depois: ollama pull llama3.1:8b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Outras opções: qwen2.5:7b (bom em JSON) | llama3.2:3b (mais leve) | mistral:7b

# --- Anthropic (nuvem, opcional) ---
# Obtenha a chave em: https://console.anthropic.com/
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
