# Renomeie este arquivo para .env e preencha os valores

# ---------------------------------------------------------------------------
# Runtime e bootstrap local
# ---------------------------------------------------------------------------
# Override opcional da workspace declarativa do agente.
# Se vazio, o loader usa: SOCC_AGENT_HOME -> ~/.socc/workspace/soc-copilot -> repo/.agents/soc-copilot
SOCC_AGENT_HOME=

# API Key da Threat Intelligence Tool (fornecida em momento oportuno)
THREAT_INTEL_API_KEY=

# URL base do backend da Threat Intelligence Tool (padrão local)
TI_API_BASE_URL=http://localhost:8000

# Credenciais do backend TI (padrão do seed_users.py)
TI_API_USER=admin
TI_API_PASS=iteam123

# Caminho absoluto para o threat_check.py
THREAT_CHECK_SCRIPT=C:\Users\Nilson.Miranda\Threat-Intelligence-Tool\backend\threat_check.py

# Pasta de saída para notas geradas
OUTPUT_DIR=C:\Users\Nilson.Miranda\OneDrive - iT.eam\Documentos\Alertas\Notas_Geradas

# Pasta raiz do projeto Alertas (para carregar regras, SOP e modelos)
ALERTAS_ROOT=C:\Users\Nilson.Miranda\OneDrive - iT.eam\Documentos\Alertas

# Porta da aplicação SOC Copilot
SOC_PORT=8080

# Máximo de IOCs individuais consultados por ofensa (para evitar rate limit)
MAX_TI_IOCS=5

# ---------------------------------------------------------------------------
# Runtime local / device / fallback
# ---------------------------------------------------------------------------
# Backend principal do runtime:
# auto | ollama | lmstudio | vllm | openai-compatible | anthropic
SOCC_INFERENCE_BACKEND=auto

# Ordem preferencial de backends quando SOCC_INFERENCE_BACKEND=auto
SOCC_BACKEND_PRIORITY=ollama,lmstudio,vllm,openai-compatible,anthropic

# Device preferido: gpu | cpu | remote
SOCC_INFERENCE_DEVICE=

# Chunking inicial da base local de conhecimento para RAG
SOCC_RAG_CHUNK_CHARS=900
SOCC_RAG_CHUNK_OVERLAP=120
SOCC_RAG_MAX_FILE_BYTES=5242880

# Provider de fallback quando o backend principal falhar
# Opções: anthropic | ollama | lmstudio | vllm | openai-compatible | cpu | deterministic
SOCC_LLM_FALLBACK_PROVIDER=anthropic

# Guarda de CPU para conter inferência local em carga alta
SOCC_CPU_GUARD_ENABLED=true
SOCC_CPU_GUARD_LOAD=4.0

# Limite de concorrência do runtime de LLM local
SOCC_MAX_CONCURRENT_LLM=2

# ---------------------------------------------------------------------------
# Feature flags operacionais
# ---------------------------------------------------------------------------
SOCC_FEATURE_ANALYZE_API=true
SOCC_FEATURE_DRAFT_API=true
SOCC_FEATURE_CHAT_API=true
SOCC_FEATURE_CHAT_STREAMING=true
SOCC_FEATURE_FEEDBACK_API=true
SOCC_FEATURE_EXPORT_API=true
SOCC_FEATURE_THREAT_INTEL=true
SOCC_FEATURE_RUNTIME_API=true

# ---------------------------------------------------------------------------
# Segurança e observabilidade
# ---------------------------------------------------------------------------
# Redige IPs, emails, URLs, hashes e segredos em logs técnicos do runtime
SOCC_LOG_REDACTION_ENABLED=true

# Se true, grava auditoria de prompts com preview redigido e fingerprint
SOCC_PROMPT_AUDIT_ENABLED=false
SOCC_PROMPT_PREVIEW_CHARS=160

# ---------------------------------------------------------------------------
# LLM — camada de análise inteligente (opcional)
# ---------------------------------------------------------------------------
# Ativa o LLM na camada semi-LLM (false = modo determinístico puro)
LLM_ENABLED=false

# Provider: "ollama" (local, padrão) ou "anthropic" (nuvem)
LLM_PROVIDER=ollama

# Timeout em segundos (Ollama pode ser mais lento na 1ª execução — GPU/CPU)
LLM_TIMEOUT=60

# --- Ollama (local) ---
# Instale em: https://ollama.com  |  depois: ollama pull llama3.1:8b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Outras opções: qwen2.5:7b (bom em JSON) | llama3.2:3b (mais leve) | mistral:7b

# --- LM Studio (OpenAI-compatible local) ---
SOCC_LMSTUDIO_URL=http://127.0.0.1:1234/v1
SOCC_LMSTUDIO_MODEL=

# --- vLLM (OpenAI-compatible, preferencial para GPU em servidor local) ---
SOCC_VLLM_URL=http://127.0.0.1:8000/v1
SOCC_VLLM_MODEL=

# --- Gateway OpenAI-compatible genérico (local ou remoto) ---
SOCC_OPENAI_COMPAT_URL=
SOCC_OPENAI_COMPAT_MODEL=

# Modelo default compartilhado entre backends locais OpenAI-compatible, quando o backend
# específico não tiver um modelo configurado acima.
SOCC_LOCAL_MODEL_DEFAULT=llama3.1:8b

# --- Anthropic (nuvem, opcional) ---
# Obtenha a chave em: https://console.anthropic.com/
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
