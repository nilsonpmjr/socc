{
  "name": "socc-vscode",
  "displayName": "SOCC",
  "description": "Practical VS Code companion for SOCC with project-aware launch behavior and a real Control Center.",
  "version": "0.1.1",
  "publisher": "devnull-bootloader",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:socc.start",
    "onCommand:socc.startInWorkspaceRoot",
    "onCommand:socc.openDocs",
    "onCommand:socc.openSetupDocs",
    "onCommand:socc.openWorkspaceProfile",
    "onCommand:socc.openControlCenter",
    "onView:socc.controlCenter"
  ],
  "main": "./src/extension.js",
  "files": [
    "README.md",
    "media/**",
    "src/extension.js",
    "src/presentation.js",
    "src/state.js",
    "themes/**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "socc.start",
        "title": "SOCC: Launch in Terminal",
        "category": "SOCC"
      },
      {
        "command": "socc.startInWorkspaceRoot",
        "title": "SOCC: Launch in Workspace Root",
        "category": "SOCC"
      },
      {
        "command": "socc.openDocs",
        "title": "SOCC: Open Repository",
        "category": "SOCC"
      },
      {
        "command": "socc.openSetupDocs",
        "title": "SOCC: Open Setup Guide",
        "category": "SOCC"
      },
      {
        "command": "socc.openWorkspaceProfile",
        "title": "SOCC: Open Workspace Profile",
        "category": "SOCC"
      },
      {
        "command": "socc.openControlCenter",
        "title": "SOCC: Open Control Center",
        "category": "SOCC"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "socc",
          "title": "SOCC",
          "icon": "media/socc.svg"
        }
      ]
    },
    "views": {
      "socc": [
        {
          "id": "socc.controlCenter",
          "name": "Control Center",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "SOCC",
      "properties": {
        "socc.launchCommand": {
          "type": "string",
          "default": "socc",
          "description": "Command run in the integrated terminal when launching SOCC."
        },
        "socc.terminalName": {
          "type": "string",
          "default": "SOCC",
          "description": "Integrated terminal tab name for SOCC sessions."
        },
        "socc.useOpenAIShim": {
          "type": "boolean",
          "default": false,
          "description": "Optionally set CLAUDE_CODE_USE_OPENAI=1 in launched SOCC terminals."
        },
        "openclaude.launchCommand": {
          "type": "string",
          "default": "socc",
          "description": "Legacy config key. Prefer socc.launchCommand."
        },
        "openclaude.terminalName": {
          "type": "string",
          "default": "SOCC",
          "description": "Legacy config key. Prefer socc.terminalName."
        },
        "openclaude.useOpenAIShim": {
          "type": "boolean",
          "default": false,
          "description": "Legacy config key. Prefer socc.useOpenAIShim."
        }
      }
    },
    "themes": [
      {
        "label": "SOCC Terminal Black",
        "uiTheme": "vs-dark",
        "path": "./themes/SOCC-Terminal-Black.json"
      }
    ]
  },
  "scripts": {
    "test": "node --test ./src/*.test.js",
    "lint": "node -e \"for (const file of require('node:fs').readdirSync('./src')) { if (file.endsWith('.js')) { require('node:child_process').execFileSync(process.execPath, ['--check', require('node:path').join('src', file)], { stdio: 'inherit' }); } }\"",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "keywords": [
    "socc",
    "terminal",
    "theme",
    "cli",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nilsonpmjr/socc"
  },
  "license": "MIT"
}
